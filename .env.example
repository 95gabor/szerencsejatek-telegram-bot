# App (defaults: PORT=8080, DATABASE_URL=file:./data/app.db, GAME_ID=otoslotto, DEFAULT_LOCALE=hu)
# Ötöslottó ingestion — public JSON (default: bet.szerencsejatek.hu PublicInfo LOTTO5&query=last)
# OTOSLOTTO_RESULT_JSON_URL=
# PORT=
# DATABASE_URL=
# DATABASE_URL supports:
# - SQLite/libSQL URLs (`file:`, `libsql:`, `https:`, `wss:`)
# - PostgreSQL URLs (`postgres://` or `postgresql://`, e.g. Deno Deploy provisioned Postgres)
# GAME_ID=
# DEFAULT_LOCALE=hu

# Telegram Bot API token from @BotFather
BOT_TOKEN=

# Public HTTPS base URL (no trailing slash) — required for auto setWebhook on server start
# (Knative / scale-to-zero). Telegram posts to WEBHOOK_URL + TELEGRAM_WEBHOOK_PATH.
# WEBHOOK_URL=https://your-host.example.com

# Optional in-process Deno Cron (default disabled):
# - false (default): no in-process scheduler
# - true: register Deno.cron hourly draw check (`0 * * * *`) in `server.ts`
# CRON_RESULT_CHECK_ENABLED=false

# Optional startup behavior for webhook mode:
# - false (default): initialize grammY + setWebhook during startup (fail fast on errors)
# - true: start HTTP server first, initialize grammY in background (helps platform warmup checks);
#   /healthz returns 503 until ready; failed init retries with backoff
# TELEGRAM_BACKGROUND_INIT=false

# Path on your service for Telegram updates (default /telegram/webhook)
# TELEGRAM_WEBHOOK_PATH=/telegram/webhook

# Optional but recommended: must match Telegram setWebhook secret_token; sent as
# X-Telegram-Bot-Api-Secret-Token
# TELEGRAM_WEBHOOK_SECRET=

# OpenTelemetry — set base URL to enable OTLP/HTTP export (traces → /v1/traces, metrics → /v1/metrics)
# OTEL_SERVICE_NAME=szerencsejatek-telegram-bot
# OTEL_SERVICE_VERSION=0.0.0
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Logging: text (default) or json (one JSON object per line); level filters handler / pipeline logs
# LOG_FORMAT=text
# LOG_LEVEL=info
